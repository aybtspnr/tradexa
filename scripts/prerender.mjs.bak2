const DIST = path.join(__dirname, "..", "dist");

// Helper: truncate strings for SEO limits (title≤60, desc≤155)
function trunc(str, max) {
  if (!str) return '';
  return str.length > max ? str.substring(0, max - 3) + '...' : str;
}
